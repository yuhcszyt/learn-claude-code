# OpenAI-compatible API configuration
#
# These tutorials call /v1/chat/completions through the OpenAI Python SDK.
# Any provider that implements the OpenAI chat-completions/tool-calls shape
# can be used by changing these three values.

# Required: API key for your provider.
OPENAI_API_KEY=sk-xxx

# Required for third-party compatible providers.
# For OpenAI itself, use: https://api.openai.com/v1
# For Tencent Cloud MaaS TokenHub, use: https://tokenhub.tencentmaas.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Required: model name provided by OPENAI_BASE_URL.
# Examples vary by provider, so fill this with the model enabled on your account.
# Tencent Cloud MaaS uses the online inference service ID as the model name,
# for example: deepseek-v3.2
OPENAI_MODEL=your-model-name

# Optional compatibility alias:
# Older local notes may still refer to MODEL_ID. The code prefers OPENAI_MODEL,
# but will fall back to MODEL_ID when OPENAI_MODEL is not set.
# MODEL_ID=your-model-name
